# Twenty CRM API Configuration
TWENTY_API_KEY=your_api_key_here
TWENTY_BASE_URL=https://api.twenty.com

# For self-hosted instances, change TWENTY_BASE_URL to your domain:
# TWENTY_BASE_URL=https://your-twenty-instance.com

# Domain for Traefik/Dokploy routing (used in docker-compose.yml labels)
MCP_DOMAIN=mcp.yourdomain.com

# Public URL of this server — required for OAuth issuer and discovery metadata
MCP_SERVER_URL=https://mcp.yourdomain.com

# SSE transport settings (used when TRANSPORT_MODE=sse)
TRANSPORT_MODE=stdio
PORT=3000

# Bearer token for authenticating MCP clients (generate with: openssl rand -hex 32)
MCP_AUTH_TOKEN=